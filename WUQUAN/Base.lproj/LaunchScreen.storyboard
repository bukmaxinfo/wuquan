                                <color key="textColor" red="0.0" green="0.87" blue="1.0" alpha="0.9" colorSpace="custom" customColorSpace="sRGB"/>
                            </label>

                            <!-- Tagline -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Dance · Battle · Drink" textAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="tagline-label">
