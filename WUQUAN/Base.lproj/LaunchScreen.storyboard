                        <viewLayoutGuide key="safeArea" id="6Tk-OE-BBY"/>

                        <!-- Background fills full screen -->
                        <constraints>
                            <constraint firstItem="bg-view-01" firstAttribute="top" secondItem="Ze5-6b-2t3" secondAttribute="top" id="bg-top"/>
                            <constraint firstItem="bg-view-01" firstAttribute="leading" secondItem="Ze5-6b-2t3" secondAttribute="leading" id="bg-lead"/>
                            <constraint firstAttribute="trailing" secondItem="bg-view-01" secondAttribute="trailing" id="bg-trail"/>
